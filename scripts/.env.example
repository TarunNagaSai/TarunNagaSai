# Copy this file to scripts/.env and fill in your real values.
#   cp scripts/.env.example scripts/.env
#
# scripts/.env is gitignored (never committed). Use APP-SPECIFIC passwords,
# not your real account password.

# --- iCloud (default provider) ---
# App-specific password: https://appleid.apple.com -> Sign-In and Security -> App-Specific Passwords
ICLOUD_USER=tarunnagasai@icloud.com
ICLOUD_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Gmail (optional, only if --provider gmail) ---
# App password: https://myaccount.google.com/apppasswords
GMAIL_USER=tarunnagasai007@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
